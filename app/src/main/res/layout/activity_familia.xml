<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ui.FamiliaActivity">

    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/pantalla_dos"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutHeaderFamilia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBackFamilia"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_volver"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/txtTituloFamilia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/family_title"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCodigo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="18dp"
        app:cardBackgroundColor="#EFFFFFFF"
        app:cardCornerRadius="22dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderFamilia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtCodigoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/family_group_code_title"
                android:textColor="#1B1B1B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCodigoHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/family_group_code_help"
                android:textColor="#4A4A4A"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCodigoBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F2F5FB"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/txtJoinCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:letterSpacing="0.12"
                        android:maxLines="1"
                        android:text="@string/family_group_code_placeholder"
                        android:textColor="#0F4BB3"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imgCodeIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/family_code_icon_description"
                        android:src="@android:drawable/ic_menu_share" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopiarCodigo"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="@string/family_copy"
                    android:textAllCaps="false"
                    android:textColor="#0F4BB3"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:strokeColor="#0F4BB3"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompartirCodigo"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:backgroundTint="#0F4BB3"
                    android:text="@string/family_share"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="14dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInvitarContactos"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#0F4BB3"
                android:text="@string/family_invite_contacts"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCrearNuevoGrupo"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="18dp"
        android:backgroundTint="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/family_create_new_group"
        android:textAllCaps="false"
        android:textColor="#0F4BB3"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:strokeColor="#0F4BB3"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/cardCodigo"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtAccionesGrupoTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/family_group_actions"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/btnCrearNuevoGrupo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/underlineAcciones"
        android:layout_width="0dp"
        android:layout_height="1.5dp"
        android:layout_marginTop="2dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/txtAccionesGrupoTitle"
        app:layout_constraintStart_toStartOf="@id/txtAccionesGrupoTitle"
        app:layout_constraintEnd_toEndOf="@id/txtAccionesGrupoTitle" />

    <LinearLayout
        android:id="@+id/layoutAccionesGrupo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/underlineAcciones"
        app:layout_constraintBottom_toTopOf="@id/bottomNavFamilia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerMiembros"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#FFFFFF"
            android:text="@string/family_view_members"
            android:textAllCaps="false"
            android:textColor="#0F4BB3"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:strokeColor="#0F4BB3"
            app:strokeWidth="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalirGrupo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#FFFFFF"
                android:text="@string/family_leave_group"
                android:textAllCaps="false"
                android:textColor="#0F4BB3"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:strokeColor="#0F4BB3"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarGrupo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#FFFFFF"
                android:text="@string/family_delete_group"
                android:textAllCaps="false"
                android:textColor="#D93A2F"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:strokeColor="#D93A2F"
                app:strokeWidth="2dp" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavFamilia"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_home_bottom_nav"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:id="@+id/navInicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_casita"
                    android:contentDescription="Inicio"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0F4BB3"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navMedicacion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/medica"
                    android:contentDescription="Medicaci&#243;n"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medicaci&#243;n"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0F4BB3"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navCitas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_citas"
                    android:contentDescription="Citas"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Citas"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0F4BB3"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navDocumentos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_docum"
                    android:contentDescription="@string/nav_docs"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_docs"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0F4BB3"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navFamilia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_fami"
                    android:contentDescription="Familia"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Familia"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0F4BB3"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
