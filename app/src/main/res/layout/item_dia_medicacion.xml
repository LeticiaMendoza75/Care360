<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutDiaMedicacion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    android:orientation="vertical"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtFechaDiaMedicacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#1B1B1B"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="16/02/2026" />

        <ImageButton
            android:id="@+id/btnEditarDiaMedicacion"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/medicacion_editar"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            tools:visibility="visible"
            app:tint="#0F4BB3" />

        <ImageButton
            android:id="@+id/btnEliminarDiaMedicacion"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/medicacion_eliminar"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_delete"
            android:visibility="gone"
            tools:visibility="visible"
            app:tint="#D83A34" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutHorasContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtHoraPreview1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_hora_medicacion"
                android:drawableStart="@drawable/ic_dot_small"
                android:drawablePadding="6dp"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text=""
                android:textColor="#1F2937"
                android:textSize="13sp"
                tools:text="08:00" />

            <TextView
                android:id="@+id/txtHoraPreview2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_hora_medicacion"
                android:drawableStart="@drawable/ic_dot_small"
                android:drawablePadding="6dp"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text=""
                android:textColor="#1F2937"
                android:textSize="13sp"
                tools:text="14:00" />

            <TextView
                android:id="@+id/txtHoraPreview3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_hora_medicacion"
                android:drawableStart="@drawable/ic_dot_small"
                android:drawablePadding="6dp"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text=""
                android:textColor="#1F2937"
                android:textSize="13sp"
                tools:text="22:00" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddHoraDia"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/medicacion_anadir_hora"
                android:textAllCaps="false"
                android:textColor="#0F4BB3"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible"
                app:backgroundTint="#EAF2FF"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="#0F4BB3" />
        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
